# Copy to .env and fill in (never commit .env)

# HTTP server (default 8080)
PORT=8080

# Postgres: local Docker (host port 5433 — see docker-compose.yml)
# Supabase production: use dashboard connection string (often sslmode=require)
DATABASE_URL=postgres://app:app@localhost:5433/app?sslmode=disable

# Redis: local — redis://localhost:6379/0
# Production (Upstash): rediss://default:PASSWORD@HOST:6379
REDIS_URL=redis://localhost:6379/0

# Comma-separated browser origins (no spaces). Example Flutter web:
# CORS_ALLOWED_ORIGINS=http://localhost:7357,http://127.0.0.1:7357
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Firebase Admin: absolute path to YOUR service account JSON from Firebase Console (Part D).
# Do not use a tutorial placeholder path — the file must exist or the server exits on startup.
GOOGLE_APPLICATION_CREDENTIALS=
